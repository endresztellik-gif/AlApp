VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_USE_MOCKS=false
VITE_APP_URL=http://localhost:5173

# Web Push (VAPID) - public key only in frontend
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY

# Admin credentials for dev scripts (never commit real values)
SUPABASE_ADMIN_EMAIL=your_admin_email
SUPABASE_ADMIN_PASSWORD=your_admin_password
SUPABASE_TEST_USER_EMAIL=your_test_user_email
SUPABASE_TEST_USER_PASSWORD=your_test_user_password
SUPABASE_NEW_PASSWORD=your_new_password
